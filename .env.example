# Copy this to .env and fill in your keys
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT signing key (generate a random 64-char hex string)
# If not set, a random key is generated on each server restart
AETHER_SECRET=

# Allowed CORS origins (comma-separated, no spaces)
# Default: * (all) — change in production to your domain
CORS_ORIGINS=*
